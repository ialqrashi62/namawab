# .env.staging.example — template for the STAGING environment (copy to .env on the staging host).
# Staging is a SEPARATE instance/DB from production. Never point this at nama_medical_web / port 5432-prod.
# All secret values are placeholders (__SET__) — fill on the staging host, never commit real secrets.

# --- Environment ---
NODE_ENV=staging                 # NOT 'production' (so test/seed paths behave) and NOT the prod DB
PORT=3000

# --- Staging database (separate instance/cluster) ---
DB_HOST=localhost
DB_PORT=5433                      # staging port — NOT 5432 (production)
DB_NAME=nama_medical_staging      # NOT nama_medical_web
DB_USER=nama_medical_app
DB_PASSWORD=__SET_STAGING_DB_PW__
DB_MAX_CONNECTIONS=20

# --- Session / Redis (use a staging redis or a separate prefix/db) ---
SESSION_SECRET=__SET_STAGING_SESSION_SECRET__
# REDIS_URL=redis://localhost:6380   # optional: separate staging redis (NOT prod 6379)

# --- Remediation feature flags (default OFF in code; turn ON to validate on staging) ---
RATE_LIMIT_GLOBAL=true            # global /api rate limiter
RATE_LIMIT_GLOBAL_MAX=600
AUDIT_ALL_MUTATIONS=true          # auto audit of /api mutations (GATE3-M1)
# CSP_ENFORCE=true                # leave UNSET first (Report-Only); enable after observing /api/csp-report

# --- E2E / test ---
E2E_TEST_PASSWORD=__SET_STAGING_E2E_PW__
