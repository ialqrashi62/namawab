# Database Configuration  (PLACEHOLDERS ONLY — copy to a git-ignored .env and set real values)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=nama_medical_web
DB_USER=postgres
DB_PASSWORD=__CHANGE_ME__
DB_MAX_CONNECTIONS=20

# Server Configuration
PORT=3000
# Required in production (the app refuses to boot without it). Generate with: openssl rand -base64 48
SESSION_SECRET=__CHANGE_ME__

# App Settings
NODE_ENV=production

# E2E local smoke test (optional; ONLY set in a local/test shell, never commit a real value).
# e2e_local_smoke_test.js fails closed if this is unset — it never hardcodes or prints a password.
E2E_TEST_PASSWORD=__CHANGE_ME__
