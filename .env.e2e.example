# E2E Smoke Test Environment Configuration Example
# Copy this file to .env or load these variables during E2E execution

# Enforce security gate (must be set to true to execute)
E2E_ALLOW_BROWSER_SMOKE=false

# Enforce Read-Only mode (skips database modification of admin password)
E2E_READ_ONLY_MODE=true

# Test Credentials (never put live/production values in this file)
E2E_TEST_USERNAME=admin
E2E_TEST_PASSWORD=YOUR_TEST_PASSWORD_HERE

# Base URL under test
E2E_BASE_URL=http://localhost:3000

# Enforce safety block for writing to test database (must be false on production)
E2E_CONFIRM_DB_WRITE=false
